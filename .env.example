# Samba 4 AD Manager — Environment Configuration Template
# Copy to .env and fill in real values:  cp .env.example .env

# ============================================
# Domain Controller
# ============================================
LDAP_SERVER=192.168.1.10
LDAP_PORT=389
LDAPS_PORT=636
DOMAIN_NAME=TEST.LOCAL
NETBIOS_NAME=TEST

# ============================================
# Bind Credentials (service account)
# ============================================
LDAP_BIND_DN=CN=Administrator,CN=Users,DC=TEST,DC=LOCAL
LDAP_BIND_PASSWORD=CHANGE_ME

# ============================================
# API Server
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
CORS_ORIGINS=http://localhost:5173

# ============================================
# Security
# ============================================
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SESSION_SECRET=CHANGE_ME

# ============================================
# LDAP Settings
# ============================================
LDAP_TIMEOUT=30
LDAP_POOL_SIZE=10
LDAP_USE_TLS=true
